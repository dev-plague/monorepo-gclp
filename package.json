{
  "name": "monorepo-gclp",
  "module": "index.ts",
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:clear": "docker compose down -v",
    "db:generate": "bun run --filter @repo/core db:generate",
    "db:migrate": "bun run --filter @repo/core db:migrate",
    "db:studio": "bun run --filter @repo/core db:studio"
  },
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "catalog": {
    "typescript": "^5.9.2",
    "@types/node": "^22.0.0"
  }
}
